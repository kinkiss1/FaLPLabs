<Window x:Class="LetterGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Генератор писем DOCX"
        Height="760"
        Width="720"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FA">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,4,0,12" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="BlockStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D5DCE5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="Автоматическая генерация писем DOCX"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,18" />

            <Border Style="{StaticResource BlockStyle}">
                <StackPanel>
                    <TextBlock Text="Адресат"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,12" />

                    <TextBlock Text="Должность адресата:" />
                    <TextBox x:Name="RecipientPostTextBox" />

                    <TextBlock Text="ФИО адресата: *" />
                    <TextBox x:Name="RecipientNameTextBox"
                             TextChanged="RequiredTextBox_TextChanged" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource BlockStyle}">
                <StackPanel>
                    <TextBlock Text="Письмо"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,12" />

                    <TextBlock Text="Тема письма: *" />
                    <TextBox x:Name="SubjectTextBox"
                             TextChanged="RequiredTextBox_TextChanged" />

                    <TextBlock Text="Текст письма: *" />
                    <TextBox x:Name="BodyTextBox"
                             Height="110"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             TextChanged="RequiredTextBox_TextChanged" />

                    <TextBlock Text="ФИО отправителя: *" />
                    <TextBox x:Name="SenderNameTextBox"
                             TextChanged="RequiredTextBox_TextChanged" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource BlockStyle}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="Приложения"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   DockPanel.Dock="Left" />
                        <Button Content="+ Добавить приложение"
                                DockPanel.Dock="Right"
                                Padding="10,4"
                                Click="AddAppendixButton_Click" />
                    </DockPanel>

                    <TextBlock Text="Если приложений нет, этот блок можно оставить пустым."
                               Foreground="Gray"
                               Margin="0,0,0,8" />

                    <StackPanel x:Name="AppendicesPanel" />
                </StackPanel>
            </Border>

            <Button Content="Сформировать DOCX"
                    Height="42"
                    FontSize="15"
                    FontWeight="Bold"
                    Click="GenerateButton_Click" />

            <TextBlock x:Name="StatusTextBlock"
                       Text="Заполните поля и нажмите «Сформировать DOCX»."
                       TextWrapping="Wrap"
                       Margin="0,16,0,0" />

            <TextBlock Text="* — поля обязательные к заполнению."
                       Foreground="Gray"
                       Margin="0,8,0,0" />
        </StackPanel>
    </ScrollViewer>
</Window>
